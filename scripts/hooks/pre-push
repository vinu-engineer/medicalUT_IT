#!/usr/bin/env bash
# =============================================================================
# pre-push hook — Patient Vital Signs Monitor (IEC 62304 Class B)
#
# Enforces:
#   1. No direct pushes to the 'main' branch (must use PR)
#   2. Branch names follow the required pattern
#
# Install: ./scripts/install-hooks.sh
# Bypass:  git push --no-verify  (requires justification in PR)
# =============================================================================

set -euo pipefail

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# ---------- Block direct push to main ----------
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo ""
    echo "ERROR: Direct push to 'main' is not allowed."
    echo ""
    echo "  All changes must go through a Pull Request."
    echo "  See: docs/BRANCHING_STRATEGY.md"
    echo ""
    echo "  To create a feature branch:"
    echo "    git checkout -b feature/<ticket>-<description>"
    echo ""
    exit 1
fi

# ---------- Validate branch name pattern ----------
BRANCH_PATTERN="^(main|feature/[A-Za-z0-9._-]+|fix/[A-Za-z0-9._-]+|hotfix/[A-Za-z0-9._-]+|release/[0-9]+\.[0-9]+\.[0-9]+|docs/[A-Za-z0-9._-]+|ci/[A-Za-z0-9._-]+|claude/[A-Za-z0-9._-]+)$"

if [ -n "$CURRENT_BRANCH" ] && ! echo "$CURRENT_BRANCH" | grep -qE "$BRANCH_PATTERN"; then
    echo ""
    echo "ERROR: Branch name '$CURRENT_BRANCH' does not match the required pattern."
    echo ""
    echo "  Valid patterns:"
    echo "    feature/<id>-<description>"
    echo "    fix/<id>-<description>"
    echo "    hotfix/<id>-<description>"
    echo "    release/<major>.<minor>.<patch>"
    echo "    docs/<description>"
    echo "    ci/<description>"
    echo ""
    echo "  Examples:"
    echo "    feature/SWR-GUI-012-localization"
    echo "    fix/BUG-042-spo2-boundary"
    echo "    release/2.9.0"
    echo ""
    exit 1
fi

exit 0
